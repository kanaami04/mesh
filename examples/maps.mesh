// map と for range:
// m[k] は V | none を返すので「無いキー」を無視できない(or / is none で処理する)

fn main() {
	ages := map<string, int>{"alice": 30, "bob": 25}
	ages["carol"] = 28

	age := ages["alice"] or 0
	print("alice is ${age}")

	missing := ages["dave"]
	if missing is none {
		print("dave is unknown")
	}

	delete(ages, "bob")
	print("${len(ages)} people")

	for k, v := range ages {
		print("${k}: ${v}")
	}

	nums := [10, 20, 30]
	mut total := 0
	for _, v := range nums {
		total = total + v
	}
	print("total: ${total}")

	for i := range 3 {
		print("tick ${i}")
	}
}
