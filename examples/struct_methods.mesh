// struct + レシーバメソッド。README記載のTodo例(生成直後のリテラルへ直接メソッドチェーンする
// `Todo{...}.complete().render()`を含む)+ フィールドの直接変更・複合代入・文字列補間を
// 組み合わせたUser例。どちらも配列/map/import無しの単一ファイルで完結する

struct Todo {
	title: string
	done: bool
}

fn (t: Todo) complete() Todo {
	return Todo{title: t.title, done: true}
}

fn (t: Todo) render() string {
	if t.done {
		return "[x] " + t.title
	}
	return "[ ] " + t.title
}

struct User {
	name: string
	age: int
}

fn (u: User) describe() string {
	return "${u.name} (${u.age})"
}

fn main() {
	mut todo := Todo{title: "write the milestone 2 report", done: false}
	print(todo.render())
	todo = todo.complete()
	print(todo.render())
	print(Todo{title: "chained", done: false}.complete().render())

	u := User{name: "alice", age: 30}
	print(u.describe())
	u.age = u.age + 1
	print(u.age)
	u.age += 1
	print(u.age)
}
