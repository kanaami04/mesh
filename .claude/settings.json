{
  "enabledPlugins": {
    "code-review@claude-code-plugins": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/enforce-squash-merge.sh\"",
            "if": "Bash(gh pr merge*)"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/enforce-code-review.sh\"",
            "if": "Bash(gh pr merge*)"
          }
        ]
      }
    ]
  }
}
